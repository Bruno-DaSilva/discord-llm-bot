146477805568","username":"meowster4792","avatar":"40f679c3dc952453df73beb46cf2009f","discriminator":"0","public_flags":0,"flags":0,"banner":null,"accent_color":null,"global_name":"Meowster","avatar_decoration_data":null,"collectibles":null,"display_name_styles":null,"banner_color":null,"clan":{"identity_guild_id":"549281623154229250","identity_enabled":true,"tag":"BAR","badge":"2d8bea68b3152b52858942d2bc854cc7"},"primary_guild":{"identity_guild_id":"549281623154229250","identity_enabled":true,"tag":"BAR","badge":"2d8bea68b3152b52858942d2bc854cc7"}}],"mention_roles":[],"attachments":[],"embeds":[],"timestamp":"2026-01-05T06:14:34.750000+00:00","edited_timestamp":null,"flags":0,"components":[],"id":"1457618261377028209","channel_id":"549282166543089674","author":{"id":"197258555018051584","username":"superkitowiec","avatar":"f65e93f1780bc4bfa5be9a7b27525000","discriminator":"0","public_flags":0,"flags":0,"banner":null,"accent_color":null,"global_name":"SuperKitowiec","avatar_decoration_data":null,"collectibles":null,"display_name_styles":null,"banner_color":null,"clan":{"identity_guild_id":"549281623154229250","identity_enabled":true,"tag":"BAR","badge":"2d8bea68b3152b52858942d2bc854cc7"},"primary_guild":{"identity_guild_id":"549281623154229250","identity_enabled":true,"tag":"BAR","badge":"2d8bea68b3152b52858942d2bc854cc7"}},"pinned":false,"mention_everyone":false,"tts":false,"message_reference":{"type":0,"channel_id":"549282166543089674","message_id":"1457593675533254782","guild_id":"549281623154229250"}}},{"type":0,"content":"All these prolly have hacks, ways to lua it. It just didn't seem efficient enough to me so i let it sleep until i can find better ways.","mentions":[],"mention_roles":[],"attachments":[],"embeds":[],"timestamp":"2026-01-05T07:30:35.806000+00:00","edited_timestamp":null,"flags":0,"components":[],"id":"1457637391832453253","channel_id":"549282166543089674","author":{"id":"248774979590684672","username":"doodvandaag","avatar":"c283e26e887d3f6766d9029688b86ed2","discriminator":"0","public_flags":0,"flags":0,"banner":null,"accent_color":null,"global_name":"DoodVanDaag","avatar_decoration_data":null,"collectibles":null,"display_name_styles":null,"banner_color":null,"clan":null,"primary_guild":null},"pinned":false,"mention_everyone":false,"tts":false},{"type":19,"content":"I tried workibg on this.\nI selfishly wanted engine to be able to handle it with less lua-ing it.\n\nThe things that i missed for an implementation are mostly:\n- Script load/unload functions for air transports: currently using functions that just notify, the attach/detach is hardcoded in engine, the function doesnt return true/false nor can delay attach/detach\n- No unitID param when unloading: game doesnt know which unit is being unloaded unless you add a thread in script that watches the load; but then its not in perfect sync with the function. Or alternatively use a unitrulesparam set from gadget when unloading is authorized (allowunittransportunload) and read from lus when effectively unloaded. You still have to deal with engine unloading prematurely.\n- limited lus <-> game <-> engine communications make it hard for the default command to properly deal with our wanted transportation limitations (ie one 3x3 and 4 2x2), since we need to ie be able to refuse 3x3 when a single 2x2 is there.\n-> I wanted unit script to be responsible for handlibg itself here: am i full? Can I load this type of unit ? Am i busy and cannot unload/load yet ? All these map to different places in the engine logic; places that we don't have as much access to as I expected i guess.\n\nI have had some decent results with custom engine adjustments but the use case is so niche that those \"adjustments\" are not really worth making.","mentions":[{"id":"197258555018051584","username":"superkitowiec","avatar":"f65e93f1780bc4bfa5be9a7b27525000","discriminator":"0","public_flags":0,"flags":0,"banner":null,"accent_color":null,"global_name":"SuperKitowiec","avatar_decoration_