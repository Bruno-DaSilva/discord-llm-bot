[{"type":19,"content":"* hardcoded attach/detach: i thought it's script responsibility already, how does the hardcoded engine behaviour choose which piece to attach?\n* no unitID: i guess you could use CommandNotify to replace `CMD_UNLOAD, {no params}` with `CMD_UNLOAD, {pick any transported unitID}`, and use `AllowCommand` to block parameter-less unload. then in the script you can rely on the unloadee unitID argument being there\n* \"can i load\": i think UI-side you could keep track of what is queued to be loaded and prevent the load command from being the rightclick default accordingly. but yeah, sounds somewhat annoying to do. i put your feedback on an engine ticket so it doesn't get lost, i'll see if i can revisit when i have some free time","mentions":[],"mention_roles":[],"attachments":[],"embeds":[],"timestamp":"2026-01-05T19:10:09.425000+00:00","edited_timestamp":"2026-01-05T19:10:17.373000+00:00","flags":0,"components":[],"id":"1457813441950519521","channel_id":"549282166543089674","author":{"id":"287055722502684683","username":"spr.ng","avatar":"ce05efcfe434157eb55fc267169cefcd","discriminator":"0","public_flags":256,"flags":256,"banner":null,"accent_color":null,"global_name":"Sprung","avatar_decoration_data":null,"collectibles":null,"display_name_styles":null,"banner_color":null,"clan":null,"primary_guild":null},"pinned":false,"mention_everyone":false,"tts":false,"message_reference":{"type":0,"channel_id":"549282166543089674","message_id":"1457639392926629889","guild_id":"549281623154229250"},"referenced_message":{"type":0,"content":"Maybe sprung and badosu can help me brainstorm how to acheive what the custom functions i wrote did, and minimize the amount of changes to engine i had in mind (maybe even none ?).","mentions":[],"mention_roles":[],"attachments":[],"embeds":[],"timestamp":"2026-01-05T07:38:32.904000+00:00","edited_timestamp":null,"flags":0,"components":[],"id":"1457639392926629889","channel_id":"549282166543089674","author":{"id":"2487749795